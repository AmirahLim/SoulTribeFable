{
  "name": "soul-tribe",
  "version": "1.0.0",
  "private": true,
  "description": "Soul Tribe — a friendship-first social app for precise compatibility and real-life connection",
  "scripts": {
    "dev": "npm run db:setup && next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "db:setup": "node --import tsx src/lib/db/migrate.ts && node --import tsx src/lib/db/seed.ts",
    "db:reset": "node -e \"require('fs').rmSync('data', { recursive: true, force: true })\" && npm run db:setup"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/nunito-sans": "^5.2.7",
    "@libsql/client": "^0.17.4",
    "@tanstack/react-query": "^5.101.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.5.2",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.17",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
